# ==============================================================================
# RISE Trader - Local Environment Configuration Template (.env.example)
# ==============================================================================
# Instructions: Copy this file to '.env' and fill in your private API tokens.
# Do NOT check the '.env' file into Git version control.

# Telegram Bot configurations
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# Application Mode (DEVELOPMENT, TESTING, PRODUCTION)
APP_ENV=DEVELOPMENT

# Log configuration directory
LOG_DIR=logs
